{
  "manifest_version": 3,
  "name": "Gmail Assistant",
  "version": "0.1.0",
  "description": "A Chrome extension for Gmail, part of Another Chrome Assistant project",
  "permissions": [
    "activeTab",
    "identity",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "oauth2": {
    "client_id": "726365485537-g0otc0f1bti0ekjo8bikm4h1ka67j6bp.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "dist/icons/icon-16.png",
      "48": "dist/icons/icon-48.png",
      "128": "dist/icons/icon-128.png"
    },
    "default_title": "Toggle side panel"
  },
  "icons": {
    "16": "dist/icons/icon-16.png",
    "48": "dist/icons/icon-48.png",
    "128": "dist/icons/icon-128.png"
  },
  "commands": {
    "toggle-sidepanel": {
      "description": "Toggle side panel"
    }
  },
  "minimum_chrome_version": "129"
}
